DATABASE_URL=postgresql://aims:aims@localhost:5432/aims
CORS_ORIGINS=http://localhost:3000
SCHEMAS_DIR=/workspace/schemas
DEFAULT_USER_EMAIL=demo@aims.local
DATA_PROVIDER=akshare
QUOTE_SYNC_DAYS=120
FILING_SYNC_DAYS=90
QUOTE_SYNC_INCREMENTAL=true
QUOTE_SYNC_OVERLAP_DAYS=5
QUOTE_SYNC_RETRIES=2
DATA_STALE_DAYS=3
DATA_SYNC_CRON_ENABLED=false
DATA_SYNC_CRON_TIME=18:30
DATA_SYNC_CRON_TZ=Asia/Shanghai
# CRON_SECRET=用于 POST /data/sync/cron

AGENT_MODE=rule
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# STRUCTURING_MODE=rule
# CIO_DECISION_MODE=batch
# CIO_DECISION_MODE=per_symbol
# CIO_REFRESH_RESEARCH=false
# CIO_MAX_SYMBOLS=12
# REBALANCE_CRON_CHAIN_AFTER_SYNC=false
# DAILY_REPORT_CRON_ENABLED=false
# DAILY_REPORT_CRON_TIME=19:05
# EVENT_RESEARCH_REFRESH_ENABLED=true
# REVIEW_CRON_ENABLED=false
# REVIEW_CRON_TIME=20:00
# REVIEW_CRON_MAX_PER_RUN=5
# NEWS_SYNC_CRON_ENABLED=false
# NEWS_SYNC_CRON_TIME=09:00
# NEWS_SYNC_MAX_SYMBOLS=8
# JWT_SECRET=change-me
# AUTH_PASSWORD=your-login-password
