{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aims.local/schemas/decision_order.schema.json",
  "title": "DecisionOrder",
  "type": "object",
  "required": [
    "security",
    "action",
    "current_weight_pct",
    "target_weight_pct",
    "decision_reason",
    "assumptions",
    "main_risks",
    "review_conditions",
    "confidence_grade",
    "holding_period",
    "decision_by"
  ],
  "properties": {
    "security": {
      "type": "object",
      "required": ["symbol", "name"],
      "properties": {
        "security_id": { "type": "string", "format": "uuid" },
        "symbol": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "action": {
      "type": "string",
      "enum": ["buy", "sell", "hold", "add", "reduce", "watch", "ban"]
    },
    "research_rating": {
      "type": "string",
      "enum": [
        "strong_buy",
        "buy",
        "hold",
        "reduce",
        "sell",
        "neutral",
        "not_applicable"
      ],
      "description": "研究观点，可与交易动作不同"
    },
    "current_weight_pct": { "type": "number", "minimum": 0, "maximum": 100 },
    "target_weight_pct": { "type": "number", "minimum": 0, "maximum": 100 },
    "delta_weight_pct": { "type": "number" },
    "decision_reason": { "type": "string" },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string" },
          "measurable": { "type": "boolean", "default": false },
          "metric_key": { "type": "string" },
          "target_value": { "type": "string" },
          "deadline": { "type": "string", "format": "date" }
        }
      }
    },
    "main_risks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "review_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "假设失效或需复盘的条件，非单纯价格止损"
    },
    "holding_period": { "type": "string" },
    "confidence_grade": { "type": "string" },
    "decision_by": { "type": "string", "default": "cio_agent" },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ref_type": {
            "type": "string",
            "enum": [
              "news",
              "filing",
              "research_report",
              "valuation",
              "factor",
              "user_note",
              "memory"
            ]
          },
          "ref_id": { "type": "string" },
          "excerpt": { "type": "string" }
        }
      }
    },
    "expected_return_range_pct": {
      "type": "object",
      "properties": {
        "low": { "type": "number" },
        "high": { "type": "number" }
      }
    }
  },
  "additionalProperties": false
}
